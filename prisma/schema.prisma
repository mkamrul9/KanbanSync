generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  boards        Board[] // Your existing relation
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  boardMemberships BoardMember[]
  assignedTasks    Task[]         @relation("AssignedTasks")
  comments         Comment[]
  sentInvites      BoardInvite[]  @relation("InviterToInvite")
  receivedInvites  BoardInvite[]  @relation("InvitedToInvite")
  notifications    Notification[]
  taskActivities   TaskActivity[]
  taskTemplates    TaskTemplate[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ... keep your existing Board, Column, and Task models below ...
model Board {
  id        String        @id @default(cuid())
  title     String
  description String?     @db.Text
  userId    String
  // The foreign key column. Stores the id of the User who owns this board. This is the actual column in the database.
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Defines the relation to the User model. fields: [userId] — the local foreign key column. references: [id] — the column in User it points to. onDelete: Cascade — if the User is deleted, all their Boards are automatically deleted too. Without this, deleting a user with boards would throw a foreign key violation error.
  columns   Column[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  members   BoardMember[] // NEW: Team members
  invites   BoardInvite[]
  taskTemplates TaskTemplate[]

  @@map("boards")
}

model BoardMember {
  id      String    @id @default(cuid())
  boardId String
  userId  String
  role    BoardRole @default(MEMBER)

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId]) // A user can only be in a board once
  @@map("board_members")
}

model Column {
  id        String   @id @default(cuid())
  title     String
  order     Int
  wipLimit  Int? // Optional WIP limit (e.g., max 3 items)
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Added this for consistency

  @@map("columns")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      String
  category    TaskCategory @default(TASK) // NEW: Enforce task types
  recurrence  RecurrenceRule @default(NONE)
  order       Int

  // NEW: Assignment
  assigneeId String?
  assignee   User?   @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)

  columnId String
  column   Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  comments Comment[]
  subtasks Subtask[]
  attachments Attachment[]
  activities TaskActivity[]

  // Timestamps for tracking workflow
  startedAt   DateTime?
  completedAt DateTime?
  dueAt       DateTime?
  reminderAt  DateTime?
  reminderSentAt DateTime?

  priority    Priority  @default(NONE)
  tags        String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

model TaskActivity {
  id        String           @id @default(cuid())
  taskId    String
  actorId   String?
  action    TaskActivityType
  message   String
  meta      Json?
  createdAt DateTime         @default(now())

  task      Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor     User?            @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@map("task_activities")
}

model TaskTemplate {
  id          String       @id @default(cuid())
  boardId     String
  createdById String?
  name        String
  title       String
  description String?      @db.Text
  category    TaskCategory @default(TASK)
  priority    Priority     @default(NONE)
  tags        String[]
  recurrence  RecurrenceRule @default(NONE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  board       Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdBy   User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([boardId, name])
  @@map("task_templates")
}

model Subtask {
  id        String   @id @default(cuid())
  title     String
  done      Boolean  @default(false)
  order     Int
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subtasks")
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  url       String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("attachments")
}

model Comment {
  id     String @id @default(cuid())
  text   String @db.Text
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("comments")
}

model BoardInvite {
  id            String    @id @default(cuid())
  boardId       String
  inviterId     String
  invitedEmail  String
  userId        String?
  role          BoardRole @default(MEMBER)
  createdAt     DateTime  @default(now())

  board       Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  inviter     User  @relation("InviterToInvite", fields: [inviterId], references: [id], onDelete: Cascade)
  user User? @relation("InvitedToInvite", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, invitedEmail])
  @@map("board_invites")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  data      Json
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  URGENT
  HIGH
  MEDIUM
  LOW
  NONE
}

enum TaskCategory {
  NEW_FEATURE
  EPIC
  STORY
  TASK
  SUB_TASK
  BUG
  ENHANCEMENT
  PATCH
  HOTFIX
}

enum BoardRole {
  LEADER
  REVIEWER
  MEMBER
}

enum RecurrenceRule {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum TaskActivityType {
  CREATED
  MOVED
  UPDATED
  COMMENTED
  ASSIGNED
  SUBTASK_ADDED
  SUBTASK_TOGGLED
  SUBTASK_DELETED
  ATTACHMENT_ADDED
  ATTACHMENT_DELETED
  TEMPLATE_SAVED
}

// TODO:
// 5. User has no password / auth field
// If you're doing credentials-based auth, there's no password or hashedPassword field. If using NextAuth/OAuth, there are no Session or Account models. This depends on your auth strategy, but it's worth noting.

// 6. No @@index on foreign keys
// Foreign key columns like userId, boardId, columnId benefit from database indexes for fast lookups:

// Without indexes, queries like "get all boards for a user" do a full table scan. Adding @@index([userId]) on Board and similar on Column and Task improves performance.
